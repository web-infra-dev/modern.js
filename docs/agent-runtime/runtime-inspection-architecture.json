            "contains": [
              {
                "id": "agent-runtime-cli",
                "name": "CLI",
                "type": "command-line-interface"
              },
              {
                "id": "http-api",
                "name": "HTTP API",
                "type": "api"
              },
              {
                "id": "sse-event-stream",
                "name": "SSE Event Stream",
                "type": "event-stream"
              }
            ]
          },
          {
            "id": "bridge-server",
            "name": "Bridge Server",
