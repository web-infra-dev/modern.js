      "types": "./dist/types/runtime/cache/index.d.ts",
      "jsnext:source": "./src/runtime/cache/index.ts",
      "require": "./dist/cjs/runtime/cache/index.js",
      "default": "./dist/esm/runtime/cache/index.js"
    }
