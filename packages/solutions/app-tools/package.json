      "runtime/server": [
        "./dist/types/runtime/exports/server.d.ts"
      ],
      "runtime/document": [
        "./dist/types/runtime/document/index.d.ts"
      ],
      "runtime/ssr": [
        "./dist/types/runtime/core/server/index.d.ts"
      ],
      "runtime/ssr/server": [
        "./dist/types/runtime/core/server/server.d.ts"
      ],
      "runtime/router": [
        "./dist/types/runtime/router/index.d.ts"
      ],
      "runtime/router/server": [
        "./dist/types/runtime/router/runtime/server.d.ts"
      ],
      "runtime/loadable-bundler-plugin": [
        "./dist/types/runtime/cli/ssr/loadable-bundler-plugin.d.ts"
