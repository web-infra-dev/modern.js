  "bin": {
    "modern": "./bin/modern.js",
    "modern-app": "./bin/modern.js"
  },
  "scripts": {
    "prepublishOnly": "only-allow-pnpm",
    "new": "modern-lib new",
    "dev": "modern-lib build --watch",
    "build": "modern-lib build",
    "test": "jest --passWithNoTests"
  },
