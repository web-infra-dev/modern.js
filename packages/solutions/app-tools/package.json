      "server": [
        "./dist/types/exports/server.d.ts"
      ],
      "deploy": [
        "./dist/types/plugins/deploy/exports.d.ts"
      ],
      "runtime": [
        "./dist/types/runtime/index.d.ts"
      ],
      "runtime/loadable": [
        "./dist/types/runtime/exports/loadable.d.ts"
      ],
      "runtime/cli": [
        "./dist/types/runtime/cli/index.d.ts"
