{
  "extends": "@modern-js/tsconfig/base",
  "compilerOptions": {
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@api/*": ["./api/*", "./api/lambda/*"],
      "@service/*": ["./api/service/*"]
    }
  },
  "include": ["api", "src"]
}
